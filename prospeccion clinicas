        "jsCode": "const msg = $input.first().json.message?.text?.toLowerCase()?.trim() || '';\nconst replyTo = $input.first().json.message?.reply_to_message?.text || '';\nconst fromChatId = String($input.first().json.message?.chat?.id || '');\n\n// Extraer nombre de clínica del mensaje original de Telegram\nconst matchNombre = replyTo.match(/Cl[ií]nica:\\s*(.+)/);\nconst nombreClinica = matchNombre ? matchNombre[1].trim() : null;\n\n// Detectar comando\nlet nuevoStatus = null;\nif (msg.includes('no interesado')) nuevoStatus = 'no_interesado';\nelse if (msg.includes('sin numero')) nuevoStatus = 'sin_numero';\nelse if (msg.includes('interesado')) nuevoStatus = 'interesado';\nelse if (msg.includes('enviado')) nuevoStatus = 'enviado';\nelse if (msg.includes('demo')) nuevoStatus = 'demo';\nelse if (msg.includes('cerrado')) nuevoStatus = 'cerrado';\n\nif (!nombreClinica || !nuevoStatus) {\n  return [{ json: { valido: false } }];\n}\n\nreturn [{ json: { valido: true, nombreClinica, nuevoStatus, fromChatId } }];"
