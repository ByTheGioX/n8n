      "parameters": {
        "jsCode": "const historyItems = $('Limit').all();\n\nhistoryItems.sort((a, b) => {\n  const dateA = new Date(a.json.created_at).getTime();\n  const dateB = new Date(b.json.created_at).getTime();\n  if (dateA !== dateB) return dateA - dateB;\n  return (a.json.id ?? 0) - (b.json.id ?? 0);\n});\n\nconst history = historyItems\n  .map(item => `[${item.json.role}]: ${item.json.content}`)\n  .join('\\n');\n\nconst doctores = $('Leer Doctores').all();\nconst horarios = $('Leer Horarios').all();\nconst servicios = $('Leer Servicios').all();\n\nconst diasSemana = {\n  '1': 'Lunes', '2': 'Martes', '3': 'Miércoles',\n  '4': 'Jueves', '5': 'Viernes', '6': 'Sábado', '7': 'Domingo'\n};\n\nconst doctoresTexto = doctores.map(d => {\n  const docId = String(d.json.doctor_id);\n  const horariosDoc = horarios\n    .filter(h => String(h.json.doctor_id) === docId)\n    .map(h => {\n  const toAmPm = (t) => {\n    const [hh, mm] = t.split(':').map(Number);\n    const period = hh >= 12 ? 'PM' : 'AM';\n    const h12 = hh % 12 === 0 ? 12 : hh % 12;\n    return `${h12}:${String(mm).padStart(2, '0')} ${period}`;\n  };\n  return `    - ${diasSemana[String(h.json.dow)]}: ${toAmPm(h.json.start_time)} a ${toAmPm(h.json.end_time)}`;\n})\n    .join('\\n');\n  const serviciosDoc = servicios\n    .filter(s => String(s.json.Doctor_ID) === docId)\n    .map(s => `    - ${s.json.nombre}`)\n    .join('\\n');\n  return `👨‍⚕️ ${d.json.nombre} — ${d.json.especialidad}\\n  calendario_id: ${d.json.calendario_id}\\n  Horarios:\\n${horariosDoc}\\n  Servicios:\\n${serviciosDoc}`;\n}).join('\\n\\n');\n\nreturn [{ json: { history, doctoresTexto } }];"
      },
